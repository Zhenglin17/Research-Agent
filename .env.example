# =============================================================================
# Research Digest Bot — secrets template
# Copy this file to .env and fill in real values. .env is gitignored.
# =============================================================================

# --- OpenRouter (LLM provider, OpenAI-compatible API) ---
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram Bot API ---
# Create a bot via @BotFather, it will give you this token.
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Logging ---
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
